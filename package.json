{
  "name": "@extra-workflow/blackglory-store-service",
  "version": "0.1.2",
  "description": "",
  "keywords": [],
  "files": [
    "lib",
    "src"
  ],
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "repository": "git@github.com:extra-workflow/blackglory-store-service.git",
  "author": "BlackGlory <woshenmedoubuzhidao@blackglory.me>",
  "license": "MIT",
  "scripts": {
    "prepare": "ts-patch install -s",
    "lint": "eslint --quiet src",
    "test": "vitest run",
    "prepublishOnly": "run-s prepare clean build",
    "clean": "rimraf lib",
    "build": "tsc --project tsconfig.build.json",
    "docker:test": "run-s docker:test:clean docker:test:build docker:test:run docker:test:clean",
    "docker:test:build": "docker compose --project-name store-js --file docker-compose.test.yml build",
    "docker:test:run": "docker compose --project-name store-js --file docker-compose.test.yml run --no-TTY --rm test",
    "docker:test:clean": "docker compose --project-name store-js --file docker-compose.test.yml down",
    "release": "standard-version"
  },
  "husky": {
    "hooks": {
      "pre-commit": "run-s prepare clean lint build docker:test",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "devDependencies": {
    "@blackglory/store-js": "^0.17.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "extra-workflow": "^0.5.0",
    "husky": "^4.3.8",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "standard-version": "^9.5.0",
    "ts-patch": "^3.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "typescript-transform-paths": "^3.5.5",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@blackglory/prelude": "^0.4.0",
    "extra-promise": "^7.1.1",
    "extra-sort": "^0.2.0",
    "extra-utils": "^6.1.0"
  },
  "peerDependencies": {
    "@blackglory/store-js": "^0.17.1",
    "extra-workflow": "^0.5.0"
  }
}
